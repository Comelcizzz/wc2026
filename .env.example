# Supabase
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=sb_publishable_your-public-key

# Leave empty for v1-compatible open-RLS mode.
# Later, you can set sb_secret_... or a legacy service-role JWT here and close RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Which pool row this deployment serves
POOL_ID=TVZAQN8G

# Admin/player session secrets
ADMIN_SECRET=change-me-to-a-long-random-string
SESSION_SECRET=change-me-to-another-long-random-string

# Picks deadline. Toronto is Eastern time; 15:00 means 3:00 PM Toronto.
PICKS_DEADLINE=2026-06-28T15:00:00-04:00
NEXT_PUBLIC_TIMEZONE=America/Toronto
